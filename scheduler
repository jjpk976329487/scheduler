    def run_once(self):
        print("\n--- Starting New Schedule Generation Run ---")
        self.display_info_needed()
        self.get_school_type()
        self.get_operational_parameters()
        self.get_course_structure_model()
        self.get_period_structure_details()
        self.get_teachers_data()
        if self.params.get('school_type') == 'Elementary': self.get_elementary_subjects()
        elif self.params.get('school_type') == 'High School': self.get_high_school_courses(); self.get_general_constraints()
        else: print("School type not set. Cannot proceed."); return
        num_schedules_to_generate = self.get_input_with_default('num_schedules_to_generate', f"How many distinct schedules to attempt (1-{MAX_DISTINCT_SCHEDULES_TO_GENERATE})?", int, lambda x: 1 <= x <= MAX_DISTINCT_SCHEDULES_TO_GENERATE)
        self.generated_schedules_details = []; generated_schedule_hashes = set()
        for attempt in range(MAX_SCHEDULE_GENERATION_ATTEMPTS * num_schedules_to_generate): # Increased attempts for diversity
            if len(self.generated_schedules_details) >= num_schedules_to_generate: break
            print(f"\n--- Schedule Gen Attempt {attempt + 1} for Distinct Sched #{len(self.generated_schedules_details) + 1} ---")
            new_schedule, run_log = self.generate_single_schedule_attempt(attempt_seed_modifier=attempt)
            if new_schedule:
                schedule_hash = hash(str(sorted(new_schedule.items()))) # Basic hash for uniqueness
                if schedule_hash not in generated_schedule_hashes:
                    self.generated_schedules_details.append({'id': len(self.generated_schedules_details) + 1, 'schedule': new_schedule, 'log': run_log})
                    generated_schedule_hashes.add(schedule_hash)
                    print(f"SUCCESS: Found new distinct schedule (ID: {self.generated_schedules_details[-1]['id']}).")
        if not self.generated_schedules_details: print("ERROR: Could not generate any valid schedules.")
        else: print(f"SUCCESS: Generated {len(self.generated_schedules_details)} distinct schedule(s).")
        self.display_schedules_console()
        if self.generated_schedules_details and self.get_input_with_default('export_pdf_choice',"\nExport to PDF?", str, lambda x: x.lower() in ['yes','no'], choices=['yes','no']).lower() == 'yes':
            self.export_schedules_pdf()

    def run(self):
        print("Welcome to the School Scheduler!")
        try:
            with open("scheduler_session_cache.tmp", "r") as f:
                self.session_cache = json.load(f)
                print("INFO: Loaded previous session data.")
        except (FileNotFoundError, json.JSONDecodeError) as e:
            if isinstance(e, FileNotFoundError): print("INFO: No previous session cache. Starting fresh.")
            else: print("WARN: Could not decode previous session cache. Starting fresh.")
            self.session_cache = {}
        while True:
            current_run_start_cache = copy.deepcopy(self.session_cache)
            try:
                self.run_once()
                try:
                    with open("scheduler_session_cache.tmp", "w") as f:
                        serializable_cache = {}
                        for k, v_item in self.session_cache.items():
                            if isinstance(v_item, (datetime.date, datetime.time, datetime.datetime)): serializable_cache[k] = v_item.isoformat()
                            elif isinstance(v_item, list):
                                serializable_list = []
                                for item_in_list in v_item:
                                    if isinstance(item_in_list, dict):
                                        s_item_dict = {ik: iv.isoformat() if isinstance(iv, (datetime.date, datetime.time, datetime.datetime)) else iv for ik, iv in item_in_list.items()}
                                        serializable_list.append(s_item_dict)
                                    else: serializable_list.append(item_in_list)
                                serializable_cache[k] = serializable_list
                            else: serializable_cache[k] = v_item
                        json.dump(serializable_cache, f, indent=2)
                except Exception as e_cache_save: print(f"Warning: Could not save session cache: {e_cache_save}")
            except Exception as e_run:
                print(f"\n!!! AN ERROR OCCURRED DURING SCHEDULE GENERATION !!!"); print(f"Error: {type(e_run).__name__}: {e_run}"); traceback.print_exc()
                print("Attempting to restore cache to state before this run to allow re-try."); self.session_cache = current_run_start_cache
            if self.get_input_with_default('make_changes_final_prompt', "Make changes and try again? (yes/no)", str, lambda x: x.lower() in ['yes', 'no'], choices=['yes','no']).lower() != 'yes':
                try:
                    if os.path.exists("scheduler_session_cache.tmp"): os.remove("scheduler_session_cache.tmp")
                except Exception as e_remove: print(f"Note: Could not remove temp cache file: {e_remove}")
                break
            self.generated_schedules_details = []; self.current_run_log = []
            print("\n" + "="*30 + " RESTARTING WITH MODIFICATIONS " + "="*30 + "\n")
        print("\n--- Script Finished ---")

