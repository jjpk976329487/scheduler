    # MODIFIED _find_qualified_teacher to handle the "Other" category rule
    def _find_qualified_teacher(self, subject_area, day_name, period_idx, teacher_busy_this_term, existing_teacher_for_offering=None):
        
        # Helper to check qualification, including the "Other" rule
        def is_qualified(teacher_obj_local, subj_area_local):
            # If the subject area is "Other", any teacher is qualified.
            if subj_area_local == "Other":
                return True
            # Otherwise, check their explicit qualifications.
            return subj_area_local in teacher_obj_local.get('qualifications', [])

        candidate_teachers = []
        if existing_teacher_for_offering:
            teacher_obj = next((t for t in self.teachers_data if t['name'] == existing_teacher_for_offering), None)
            if teacher_obj and \
               is_qualified(teacher_obj, subject_area) and \
               teacher_obj.get('availability', {}).get(day_name, {}).get(period_idx, False) and \
               (day_name, period_idx) not in teacher_busy_this_term.get(existing_teacher_for_offering, set()):
                return existing_teacher_for_offering
            else:
                return None

        for teacher in self.teachers_data:
            if is_qualified(teacher, subject_area) and \
               teacher.get('availability', {}).get(day_name, {}).get(period_idx, False) and \
               (day_name, period_idx) not in teacher_busy_this_term.get(teacher['name'], set()):
                candidate_teachers.append(teacher['name'])
        return random.choice(candidate_teachers) if candidate_teachers else None

    def generate_single_schedule_attempt(self, attempt_seed_modifier=0):
        self.current_run_log = [f"--- Attempting Schedule Generation (Seed Mod: {attempt_seed_modifier}) ---"]
        num_p_day = self.params.get('num_periods_per_day',1)
        num_terms = self.params.get('num_terms',1)
        current_schedule = {t: {d: [None]*num_p_day for d in DAYS_OF_WEEK} for t in range(1, num_terms + 1)}

        items_by_term = defaultdict(list)
        source_data = self.subjects_data if self.params.get('school_type') == 'Elementary' else self.courses_data
        if not source_data: self._log_message("No subjects/courses defined.", "WARN"); return None, self.current_run_log

        for item_data_orig in source_data:
            item_data = copy.deepcopy(item_data_orig)
            term_num_item = item_data.get('term_assignment', 1)
            is_elem = self.params.get('school_type') == 'Elementary'
            num_terms_for_this_item = num_terms if is_elem else 1

            for t_offset in range(num_terms_for_this_item):
                actual_term_for_item = term_num_item + t_offset if not is_elem else t_offset + 1
                if actual_term_for_item > num_terms: continue
                
                # subject_area should be correctly populated from QUALIFIABLE_SUBJECTS by input functions
                # Fallback here is a safeguard, ideally not hit.
                default_subj_area = "Other" # Default to "Other" if somehow not set
                
                items_by_term[actual_term_for_item].append({
                    'name': item_data['name'], 'teacher': None,
                    'subject_area': item_data.get('subject_area', default_subj_area),
                    'periods_to_schedule_this_week': item_data.get('periods_per_week', item_data.get('periods_per_week_in_active_term', 0)),
                    'constraints': item_data.get('parsed_constraints', []),
                    'type': 'subject' if is_elem else 'course'
                })

        for term_idx in range(1, num_terms + 1):
            self._log_message(f"\nScheduling Term {term_idx}...", "DEBUG")
            must_assign_items, flexible_items_all = [], []
            for item in items_by_term[term_idx]:
                if any(c.get('type') == 'ASSIGN' for c in item.get('constraints', [])): must_assign_items.append(item)
                else: flexible_items_all.append(item)

            teacher_busy_this_term = defaultdict(set)
            item_scheduled_on_day_this_term = defaultdict(set)

            for item in must_assign_items:
                item_name, item_subj_area = item['name'], item.get('subject_area')
                assigned_slots_constr = [c for c in item.get('constraints', []) if c.get('type') == 'ASSIGN']
                if not item_subj_area: self._log_message(f"ASSIGN item '{item_name}' missing subject area (should be one of {QUALIFIABLE_SUBJECTS}).", "ERROR"); return None, self.current_run_log

                teacher_for_all_slots = None
                # Find a teacher qualified for item_subj_area (respecting "Other" rule via _find_qualified_teacher logic)
                # For ASSIGN, we need one teacher for ALL assigned slots.
                # We can't use _find_qualified_teacher directly here as it's slot-specific.
                # We need a teacher whose 'qualifications' list contains item_subj_area OR if item_subj_area is "Other"
                
                potential_teachers_for_assign = []
                for t_obj in self.teachers_data:
                    is_assign_qualified = False
                    if item_subj_area == "Other": # "Other" rule
                        is_assign_qualified = True
                    elif item_subj_area in t_obj.get('qualifications', []):
                        is_assign_qualified = True
                    
                    if is_assign_qualified:
                        potential_teachers_for_assign.append(t_obj['name'])

                for teacher_cand_name in potential_teachers_for_assign:
                    teacher_obj_cand = next((t for t in self.teachers_data if t['name'] == teacher_cand_name), None)
                    if not teacher_obj_cand: continue 
                    available_all = True
                    for slot_c in assigned_slots_constr:
                        day_c, period_c = slot_c['day'], slot_c['period']
                        if not teacher_obj_cand['availability'].get(day_c,{}).get(period_c,False) or \
                           (day_c,period_c) in teacher_busy_this_term.get(teacher_cand_name,set()):
                            available_all=False; break
                    if available_all: teacher_for_all_slots = teacher_cand_name; break

                if not teacher_for_all_slots: self._log_message(f"No single qualified teacher for all ASSIGN slots of '{item_name}' (Subject: {item_subj_area}).", "ERROR"); return None, self.current_run_log
                item['teacher'] = teacher_for_all_slots

                all_slots_placed_successfully = True
                for slot_c in assigned_slots_constr:
                    day_c, period_c = slot_c['day'], slot_c['period']
                    if not (0 <= period_c < num_p_day): self._log_message(f"ASSIGN slot for '{item_name}' out of bounds.", "ERROR"); all_slots_placed_successfully=False; break
                    if current_schedule[term_idx][day_c][period_c] is not None: self._log_message(f"ASSIGN slot for '{item_name}' already taken.", "ERROR"); all_slots_placed_successfully=False; break
                    if any((c.get('day') is None or c.get('day')==day_c) and c.get('period')==period_c for c in item.get('constraints',[]) if c.get('type')=='NOT'): self._log_message(f"ASSIGN item '{item_name}' has conflicting NOT constraint.", "ERROR"); all_slots_placed_successfully=False; break

                if all_slots_placed_successfully:
                    for slot_c in assigned_slots_constr:
                        day_c, period_c = slot_c['day'], slot_c['period']
                        current_schedule[term_idx][day_c][period_c] = (item_name, teacher_for_all_slots)
                        teacher_busy_this_term[teacher_for_all_slots].add((day_c, period_c))
                        item_scheduled_on_day_this_term[item_name].add(day_c)
                    self._log_message(f"Scheduled ASSIGN item '{item_name}' (T:{teacher_for_all_slots}).", "DEBUG")
                else: self._log_message(f"Failed to place all ASSIGN slots for '{item_name}'.", "CRITICAL"); return None, self.current_run_log

            flexible_items_processed = sorted(flexible_items_all, key=lambda x: x.get('periods_to_schedule_this_week',0), reverse=True)
            if attempt_seed_modifier > 0: random.seed(datetime.datetime.now().microsecond + attempt_seed_modifier + term_idx); random.shuffle(flexible_items_processed)
            days_order = DAYS_OF_WEEK[:]; period_indices_order_base = list(range(num_p_day))
            if attempt_seed_modifier > 0 and attempt_seed_modifier % 2 == 1 : random.shuffle(days_order)

            for item in flexible_items_processed:
                item_name, item_subj_area = item['name'], item.get('subject_area')
                not_constraints = [c for c in item.get('constraints',[]) if c.get('type') == 'NOT']
                periods_to_place = item.get('periods_to_schedule_this_week',0); placed_count = 0
                item_teacher_for_offering = item.get('teacher') # This will be None initially for flexible items

                if not item_subj_area: self._log_message(f"Flexible item '{item_name}' missing subject area (should be one of {QUALIFIABLE_SUBJECTS}).", "WARN"); continue

                for _ in range(periods_to_place):
                    slot_found_this_instance = False
                    period_indices_order = period_indices_order_base[:]
                    if attempt_seed_modifier > 0 and placed_count % (3+attempt_seed_modifier%2) == 0 : random.shuffle(period_indices_order)

                    for day_name_flex in days_order:
                        if slot_found_this_instance: break
                        for period_idx_flex in period_indices_order:
                            if current_schedule[term_idx][day_name_flex][period_idx_flex] is None:
                                # _find_qualified_teacher now incorporates the "Other" rule
                                teacher_for_this_slot = self._find_qualified_teacher(item_subj_area, day_name_flex, period_idx_flex, teacher_busy_this_term, item_teacher_for_offering)
                                if not teacher_for_this_slot: continue

                                if not item_teacher_for_offering:
                                    item_teacher_for_offering = teacher_for_this_slot
                                    item['teacher'] = item_teacher_for_offering # Update item dict for this schedule attempt
                                elif item_teacher_for_offering != teacher_for_this_slot:
                                    continue

                                if any((c.get('day') is None or c.get('day')==day_name_flex) and c.get('period')==period_idx_flex for c in not_constraints): continue
                                if not self.params.get('multiple_times_same_day',True) and day_name_flex in item_scheduled_on_day_this_term.get(item_name,set()): continue

                                current_schedule[term_idx][day_name_flex][period_idx_flex] = (item_name, item_teacher_for_offering)
                                teacher_busy_this_term[item_teacher_for_offering].add((day_name_flex, period_idx_flex))
                                item_scheduled_on_day_this_term[item_name].add(day_name_flex)
                                placed_count += 1; slot_found_this_instance = True; break
                    if not slot_found_this_instance: self._log_message(f"Could not find slot for an instance of '{item_name}'.", "WARN"); break

                if placed_count < periods_to_place: self._log_message(f"Failed to schedule all {periods_to_place} for '{item_name}'. Scheduled {placed_count}.", "ALERT")
                elif item_teacher_for_offering: self._log_message(f"Scheduled '{item_name}' (T:{item_teacher_for_offering}) for {placed_count} periods.", "DEBUG")
                else: self._log_message(f"Scheduled {placed_count} for '{item_name}', but no teacher assigned (Subject: {item_subj_area}).", "WARN")
            self._log_message(f"Term {term_idx} scheduling complete.", "DEBUG")
        self._log_message("Schedule Generation Attempt Finished.", "INFO")
        return current_schedule, self.current_run_log

    def _calculate_period_times_for_display(self):
        num_p = self.params.get('num_periods_per_day', 0); p_dur = self.params.get('period_duration_minutes', 0); b_dur = self.params.get('break_between_classes_minutes', 0)
        s_start_t, l_start_t, l_end_t = self.params.get('school_start_time'), self.params.get('lunch_start_time'), self.params.get('lunch_end_time')
        if not all([num_p > 0, p_dur > 0, s_start_t, l_start_t, l_end_t]): return [f"" for _ in range(num_p)]
        s_start_m, l_start_m, l_end_m = time_to_minutes(s_start_t), time_to_minutes(l_start_t), time_to_minutes(l_end_t)
        times = []; current_m = s_start_m
        for i in range(num_p): # Corrected loop variable from _ to i
            is_before_lunch = current_m + p_dur <= l_start_m
            is_after_lunch = current_m >= l_end_m
            
            if not is_before_lunch and not is_after_lunch: # Straddles or is within lunch
                current_m = l_end_m # Move current time to after lunch

            slot_s = current_m
            slot_e = current_m + p_dur
            
            times.append(f"{format_time_from_minutes(slot_s)}-{format_time_from_minutes(slot_e)}")
            current_m = slot_e
            if i < num_p -1 : # Add break if not the last period of the day
                 current_m += b_dur
        return times


