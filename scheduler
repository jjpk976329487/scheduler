            if self.params['start_date']:
                self.session_cache['start_date_str'] = start_date_str
                break
            else: # Corrected
                print("Invalid date format.")

        while True:
            end_date_str = self.get_input_with_default('end_date_str', "School Year End Date (YYYY-MM-DD)", str)
            self.params['end_date'] = parse_date(end_date_str)
            start_dt = self.params.get('start_date')
            if self.params['end_date'] and start_dt and self.params['end_date'] > start_dt:
                self.session_cache['end_date_str'] = end_date_str
                break
            else: # Corrected
                print("Invalid date format or end date not after start date.")

        self.params['non_instructional_days_str'] = self.get_input_with_default('non_instructional_days_str', "Non-instructional days (YYYY-MM-DD, comma-separated)", str, allow_empty=True)

        while True:
            start_time_str = self.get_input_with_default('start_time_str', "Daily School Start Time (HH:MM AM/PM or HH:MM)", str)
            self.params['school_start_time'] = parse_time(start_time_str)
            if self.params['school_start_time']:
                self.session_cache['start_time_str'] = start_time_str
                break
            else: # Corrected
                print("Invalid time format.")

        while True:
            end_time_str = self.get_input_with_default('end_time_str', "Daily School End Time (HH:MM AM/PM or HH:MM)", str)
            self.params['school_end_time'] = parse_time(end_time_str)
            school_st = self.params.get('school_start_time')
            if self.params['school_end_time'] and school_st and time_to_minutes(self.params['school_end_time']) > time_to_minutes(school_st):
                self.session_cache['end_time_str'] = end_time_str
                break
            else: # Corrected
                print("Invalid time format or end time not after start.")

        while True:
            lunch_start_str = self.get_input_with_default('lunch_start_time_str', "Lunch Start Time (HH:MM AM/PM or HH:MM)", str)
            self.params['lunch_start_time'] = parse_time(lunch_start_str)
            school_st = self.params.get('school_start_time'); school_et = self.params.get('school_end_time')
            if self.params['lunch_start_time'] and school_st and school_et and \
               time_to_minutes(self.params['lunch_start_time']) >= time_to_minutes(school_st) and \
               time_to_minutes(self.params['lunch_start_time']) < time_to_minutes(school_et):
                self.session_cache['lunch_start_time_str'] = lunch_start_str
                break
            else: # Corrected
                print("Invalid time or lunch outside school hours.")

        while True:
            lunch_end_str = self.get_input_with_default('lunch_end_time_str', "Lunch End Time (HH:MM AM/PM or HH:MM)", str)
            self.params['lunch_end_time'] = parse_time(lunch_end_str)
            lunch_st = self.params.get('lunch_start_time'); school_et = self.params.get('school_end_time')
            if self.params['lunch_end_time'] and lunch_st and school_et and \
               time_to_minutes(self.params['lunch_end_time']) > time_to_minutes(lunch_st) and \
               time_to_minutes(self.params['lunch_end_time']) <= time_to_minutes(school_et):
                self.session_cache['lunch_end_time_str'] = lunch_end_str
                break
            else: # Corrected
                print("Invalid time or lunch end not after start / outside school hours.")

        multiple_choice = self.get_input_with_default(
            'multiple_times_same_day_choice',
            "Can classes appear multiple times same day for same grade/cohort?",
            str, lambda x: x.lower() in ['yes', 'no'], choices=['yes', 'no']
        )
        self.params['multiple_times_same_day'] = multiple_choice.lower() == 'yes'

        self.params['instructional_days'] = calculate_instructional_days(self.params.get('start_date'), self.params.get('end_date'), self.params.get('non_instructional_days_str',''))
        self.session_cache['instructional_days'] = self.params['instructional_days']
        self._log_message(f"Calculated Instructional Days: {self.params['instructional_days']}", "DEBUG")
        num_id = self.params.get('instructional_days',0)
        self.params['num_instructional_weeks'] = math.ceil(num_id / 5) if num_id > 0 else 0
        self.session_cache['num_instructional_weeks'] = self.params['num_instructional_weeks']
        self._log_message(f"Estimated instructional weeks: {self.params['num_instructional_weeks']}", "DEBUG")

    def get_course_structure_model(self):
        self._log_message("--- Course Structure Model ---", "DEBUG")
        model_choices_map = {"Quarterly": ("Quarterly", 4), "Semester": ("Semester", 2), "Full Year": ("Full Year", 1)}
        model_display_choices = list(model_choices_map.keys())
        chosen_model_text = self.get_input_with_default('course_model_choice_text', "Select scheduling model", str, lambda x: x in model_display_choices, choices=model_display_choices)
        self.params['scheduling_model'], self.params['num_terms'] = model_choices_map[chosen_model_text]
        self._log_message(f"Selected model: {self.params['scheduling_model']} ({self.params['num_terms']} term(s))", "DEBUG")
        weeks_per_term_val = 0
        num_iw = self.params.get('num_instructional_weeks',0); num_t = self.params.get('num_terms',0)
        if num_iw > 0 and num_t > 0: weeks_per_term_val = math.ceil(num_iw / num_t)
        self.params['weeks_per_term'] = weeks_per_term_val
        self.session_cache['weeks_per_term'] = weeks_per_term_val
        self._log_message(f"Estimated weeks per term: {self.params['weeks_per_term']}", "DEBUG")

    def get_period_structure_details(self):
        self._log_message("--- Daily Period Structure ---", "DEBUG")
        self.params['num_periods_per_day'] = self.get_input_with_default('num_periods_per_day', "Number of teaching periods/day", int, lambda x: x > 0)
        self.params['period_duration_minutes'] = self.get_input_with_default('period_duration_minutes', "Duration of each period (minutes)", int, lambda x: x > 0)
        breaks_val_str = self.get_input_with_default('break_between_classes_minutes_str', "Duration of breaks between classes (minutes, default 5)", str, allow_empty=True)
        self.params['break_between_classes_minutes'] = int(breaks_val_str) if breaks_val_str else 5
        if self.params['break_between_classes_minutes'] < 0: self._log_message("Break duration cannot be negative. Setting to 0.", "WARN"); self.params['break_between_classes_minutes'] = 0
        self.session_cache['break_between_classes_minutes'] = self.params['break_between_classes_minutes']
        s_start_t = self.params.get('school_start_time'); s_end_t = self.params.get('school_end_time'); l_start_t = self.params.get('lunch_start_time'); l_end_t = self.params.get('lunch_end_time')
        available_min = 0
        if s_start_t and s_end_t and l_start_t and l_end_t:
            s_start_m, s_end_m, l_start_m, l_end_m = time_to_minutes(s_start_t), time_to_minutes(s_end_t), time_to_minutes(l_start_t), time_to_minutes(l_end_t)
            if s_end_m > s_start_m and l_end_m > l_start_m: available_min = (s_end_m - s_start_m) - (l_end_m - l_start_m)
        num_p, p_dur, b_dur = self.params.get('num_periods_per_day', 0), self.params.get('period_duration_minutes', 0), self.params.get('break_between_classes_minutes', 0)
        required_min = (num_p * p_dur) + (max(0, num_p - 1) * b_dur)
        if required_min > available_min and available_min > 0 : self._log_message(f"Daily schedule might not fit! Required: {required_min} min, Available: {available_min} min.", "WARNING")
        elif available_min <= 0: self._log_message("School/lunch times might be invalid for fit calculation.", "WARNING")
        else: self._log_message("Daily schedule parameters seem to fit.", "DEBUG")
        total_annual_hours = (self.params.get('instructional_days', 0) * num_p * p_dur) / 60
        self.params['total_annual_instructional_hours'] = total_annual_hours
        self.session_cache['total_annual_instructional_hours'] = total_annual_hours
        self._log_message(f"Calculated Total Annual Instructional Hours: {total_annual_hours:.2f}.", "DEBUG")
        min_hours = self.params.get('min_instructional_hours', 0)
        if total_annual_hours < min_hours: self._log_message(f"Hours ({total_annual_hours:.2f}) BELOW Alberta minimum of {min_hours} hrs for {self.params.get('school_type','N/A')}.", "WARNING")
        else: self._log_message("Hours meet/exceed Alberta minimum.", "DEBUG")

